# Supabase project used to record community suggestions (see docs/SUPABASE.md).
# Both values are public-safe: the anon key is protected by an INSERT-only
# Row Level Security policy. Leave blank to run with localStorage-only
# submissions (the app degrades gracefully).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Web Analytics beacon token (Cloudflare dashboard > Analytics & Logs
# > Web Analytics > Add a site). Public-safe by design. Leave blank to run
# without the beacon script (the app degrades gracefully).
NEXT_PUBLIC_CF_BEACON_TOKEN=
